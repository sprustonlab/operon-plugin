# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Virtual env
.venv/
venv/

# Tests / build artifacts
.test_results/

# Stray per-member lockfile. The uv workspace root owns the single
# uv.lock; a standalone `uv run --project plugins/operon-plugin` (e.g.
# the bin shim) can drop one here -- don't track it.
plugins/operon-plugin/uv.lock

# MkDocs build output (regenerated by the docs.yml Pages deploy)
site/

# Operon project-local state. Ephemeral runtime state -- the run-dirs
# (.operon/<run_name>/), _active.json, and _handles/ -- is never tracked.
# Authored project-tier config -- .operon/workflows/ and .operon/rules.yaml
# -- IS committed, so it is re-included below.
.operon/*
!.operon/workflows/
!.operon/rules.yaml
# Fixture seed trees ship project-tier state copied into each scenario's
# tmp_cwd at test start.
!tests/fixtures/**/.operon/
!tests/fixtures/**/.operon/**

# Local Claude Code team/agent state (per-machine; never tracked)
.claude/

# Operon run work products are tracked on `develop` only; on `main` they
# are ignored so the shipped plugin tree stays free of run audit trails.
operon-runs/

# OS
.DS_Store
Thumbs.db
