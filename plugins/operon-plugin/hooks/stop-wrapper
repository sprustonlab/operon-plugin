#!/usr/bin/env bash
# Stop hook wrapper (Phase 8). Same uv -> python3 -> python pre-flight-
# import-check ladder as `pretooluse-wrapper` and `bin/operon-mcp-server`.
# Reads stdin / writes stdout transparently.

set -e

plugin_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." >/dev/null 2>&1 && pwd -P)"
script="${plugin_root}/hooks/stop.py"

export PYTHONPATH="${plugin_root}/src${PYTHONPATH:+:${PYTHONPATH}}"

if command -v uv >/dev/null 2>&1; then
    exec uv run --project "${plugin_root}" python "${script}" "$@"
fi

for py in python3 python; do
    if command -v "$py" >/dev/null 2>&1; then
        if "$py" -c "import mcp, watchdog, yaml" >/dev/null 2>&1; then
            exec "$py" "${script}" "$@"
        fi
    fi
done

cat >&2 <<'EOF'
operon-plugin stop hook: no python with required deps. Install uv
or pip install: mcp>=1.0 watchdog>=4.0 PyYAML>=6.0
EOF
# Emit a benign no-op response so Claude Code doesn't surface the
# missing-dep as a hook error noise; the user already sees the
# stderr line in the MCP log when this happens.
printf '%s' '{}'
exit 0
